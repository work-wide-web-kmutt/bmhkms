{
  "name": "bmhkms",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.28",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.9",
      "evlog": "^2.14.1",
      "next-themes": "^0.4.6",
      "@orpc/client": "^1.13.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "auth:generate": "bun run --cwd apps/server auth:generate",
    "auth:info": "bun run --cwd apps/server auth:info",
    "auth:secret": "bun run --cwd apps/server auth:secret",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @bmhkms/db db:push",
    "db:studio": "turbo -F @bmhkms/db db:studio",
    "db:generate": "turbo -F @bmhkms/db db:generate",
    "db:migrate": "turbo -F @bmhkms/db db:migrate",
    "db:start": "turbo -F @bmhkms/db db:start",
    "db:watch": "turbo -F @bmhkms/db db:watch",
    "db:stop": "turbo -F @bmhkms/db db:stop",
    "db:down": "turbo -F @bmhkms/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@bmhkms/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bmhkms/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.7.0"
  },
  "packageManager": "bun@1.3.5"
}
