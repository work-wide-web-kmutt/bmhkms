{
  "name": "bmhkms",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.28",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@orpc/client": "^1.13.14",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "auth": "1.6.11",
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
      "vite-plus": "0.2.2"
    }
  },
  "type": "module",
  "scripts": {
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "commitlint:check": "commitlint --from HEAD~1 --to HEAD --verbose",
    "dev": "vp run -r dev",
    "build": "vp run -r build",
    "check-types": "vp run -r check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "staged": "vp staged",
    "hooks:setup": "vp config",
    "dev:web": "vp run --filter web dev",
    "dev:staff": "vp run --filter staff dev",
    "dev:server": "vp run --filter server dev",
    "build:staff": "vp run --filter staff build",
    "db:push": "vp run --filter @bmhkms/db db:push",
    "db:studio": "vp run --filter @bmhkms/db db:studio",
    "db:generate": "vp run --filter @bmhkms/db db:generate",
    "db:migrate": "vp run --filter @bmhkms/db db:migrate",
    "db:start": "docker compose up -d postgres",
    "db:watch": "docker compose up postgres",
    "db:stop": "docker compose stop postgres",
    "db:down": "docker compose down postgres",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@bmhkms/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bmhkms/config": "workspace:*",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/cz-commitlint": "^21.0.0",
    "@types/bun": "catalog:",
    "commitizen": "^4.3.1",
    "inquirer": "^9.3.7",
    "oxfmt": "latest",
    "oxlint": "latest",
    "rolldown": "1.1.0",
    "skills": "^1.5.14",
    "typescript": "catalog:",
    "ultracite": "7.8.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "packageManager": "bun@1.3.5"
}
