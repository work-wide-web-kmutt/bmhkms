{
  "name": "server",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "vp pack",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/main.ts --outfile server",
    "dev": "bun run --hot src/main.ts",
    "start": "bun run dist/main.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bmhkms/api": "workspace:*",
    "@bmhkms/auth": "workspace:*",
    "@bmhkms/env": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "elysia": "catalog:",
    "evlog": "^2.18.1"
  },
  "devDependencies": {
    "@bmhkms/config": "workspace:*",
    "@orpc/client": "catalog:",
    "@types/bun": "catalog:",
    "@vitest/coverage-v8": "4.1.9",
    "dotenv": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.9"
  }
}
