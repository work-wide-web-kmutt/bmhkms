{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "auth:generate": "better-auth generate --config ../../packages/auth/src/index.ts --output ../../packages/db/src/schema/auth.ts --yes",
    "auth:info": "better-auth info --config ../../packages/auth/src/index.ts",
    "auth:secret": "better-auth secret",
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@bmhkms/api": "workspace:*",
    "@bmhkms/auth": "workspace:*",
    "@bmhkms/db": "workspace:*",
    "@bmhkms/env": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@sinclair/typebox": "^0.34.49",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "catalog:",
    "evlog": "^2.18.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bmhkms/config": "workspace:*",
    "@types/bun": "catalog:",
    "auth": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
