{
  "name": "@bmhkms/auth",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "auth:generate": "DOTENV_CONFIG_PATH=../../apps/server/.env better-auth generate --config ./src/index.ts --output ../db/src/schema/auth.ts --yes",
    "auth:info": "DOTENV_CONFIG_PATH=../../apps/server/.env better-auth info --config ./src/index.ts",
    "auth:secret": "DOTENV_CONFIG_PATH=../../apps/server/.env better-auth secret"
  },
  "dependencies": {
    "@bmhkms/db": "workspace:*",
    "@bmhkms/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bmhkms/config": "workspace:*",
    "auth": "catalog:",
    "typescript": "catalog:"
  }
}
